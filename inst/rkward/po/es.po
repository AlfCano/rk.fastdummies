msgid "Create Dummy Variables"
msgstr "Crear Variables Dummy"

msgid "An RKWard plugin to create dummy variables (one-hot encoding) from survey or dataframe objects using the 'fastDummies' package."
msgstr "Un plugin de RKWard para crear variables dummy (codificación one-hot) a partir de encuestas o data frames usando el paquete 'fastDummies'."

msgid "Create Dummy Variables (fastDummies)"
msgstr "Crear Variables Dummy (fastDummies)"

msgid "Input Data (Data Frame or Survey Object)"
msgstr "Datos de entrada (Data Frame u Objeto de Encuesta)"

msgid "Columns to expand (Leave empty to expand all factor/char columns)"
msgstr "Columnas a expandir (Dejar vacío para todas las columnas de factor/carácter)"

msgid "Remove first dummy variable (Avoids collinearity)"
msgstr "Eliminar la primera variable dummy (Evita colinealidad)"

msgid "Remove most frequent dummy variable"
msgstr "Eliminar la variable dummy más frecuente"

msgid "Ignore NA rank (Preserve NAs)"
msgstr "Ignorar rango NA (Preservar NAs)"

msgid "Remove original columns after creating dummies"
msgstr "Eliminar columnas originales tras crear dummies"

msgid "Save Results to R Object"
msgstr "Guardar resultados en objeto R"

msgid "Dummy Creation Rules"
msgstr "Reglas de creación de Dummies"

