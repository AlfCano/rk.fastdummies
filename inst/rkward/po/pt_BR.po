msgid "Create Dummy Variables"
msgstr "Criar Variáveis Dummy"

msgid "An RKWard plugin to create dummy variables (one-hot encoding) from survey or dataframe objects using the 'fastDummies' package."
msgstr "Um plugin RKWard para criar variáveis dummy (codificação one-hot) a partir de objetos de pesquisa (survey) ou data frames usando o pacote 'fastDummies'."

msgid "Create Dummy Variables (fastDummies)"
msgstr "Criar Variáveis Dummy (fastDummies)"

msgid "Input Data (Data Frame or Survey Object)"
msgstr "Dados de Entrada (Data Frame ou Objeto de Survey)"

msgid "Columns to expand (Leave empty to expand all factor/char columns)"
msgstr "Colunas para expandir (Deixe vazio para fatores/caracteres)"

msgid "Remove first dummy variable (Avoids collinearity)"
msgstr "Remover primeira variável dummy (Evita colinearidade)"

msgid "Remove most frequent dummy variable"
msgstr "Remover a variável dummy mais frequente"

msgid "Ignore NA rank (Preserve NAs)"
msgstr "Ignorar nível NA (Preservar NAs)"

msgid "Remove original columns after creating dummies"
msgstr "Remover colunas originais após criação"

msgid "Save Results to R Object"
msgstr "Salvar resultados no objeto R"

msgid "Dummy Creation Rules"
msgstr "Regras de Criação"

msgid "Data Cleaning"
msgstr "Limpeza de Dados"

msgid "Variables"
msgstr "Variáveis"

msgid "Settings"
msgstr "Configurações"

msgid "Output"
msgstr "Saída"

msgid "Data Wrangling"
msgstr "Manipulação de Dados"

